# Copy this file to bridge/.env and fill in your values.
# bridge/.env is gitignored — never commit secrets.

# Path to Factorio's script-output directory.
# For Docker: path to the mounted volume on the host.
# For local Factorio client on macOS: ~/Library/Application Support/factorio/script-output/ai-player
FACTORIO_OUTPUT_DIR=/Users/yourname/code/virtual/factorio-docker/data/script-output/ai-player

# RCON credentials (must match Factorio server config / docker-compose env)
FACTORIO_RCON_HOST=localhost
FACTORIO_RCON_PORT=27015
FACTORIO_RCON_PASSWORD=your_rcon_password

# Default provider (lmstudio | openai | anthropic | custom)
AI_PROVIDER=lmstudio

# Model name as reported by your provider. If set here, it OVERRIDES the in-game
# mod model setting (config.json) — set it here to switch models from the bridge
# side. Comment it out to let the in-game "ai-player-model-name" setting control it.
AI_MODEL=local-model

# LM Studio / local server URL
LM_STUDIO_URL=http://localhost:1234/v1

# API keys — only needed for the matching provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# SINGLE SOURCE for how long a model is allowed to reply (seconds). The mod's
# pending-request timeout and the watcher's stale timeout are derived from this
# (AI_TIMEOUT + margin), so nothing ever times out faster than the model can
# answer. Measure your model's real latency first: `python -m bridge.benchmark`,
# then set this at or above its recommendation. Slow local models may need 240+.
AI_TIMEOUT=240

# Output token budget per turn. Keep this generous (default 8192): with a large
# entity-mapping perception the model needs room to emit the full JSON array —
# too low truncates the response and parsing fails (confirmed at 2048).
AI_MAX_TOKENS=8192

# Sampling temperature (0.0–1.0). Lower = more deterministic action output.
AI_TEMPERATURE=0.7

# Optional text prepended to the system prompt for model-specific directives.
# NOTE: for nvidia/nemotron-3-super this did NOT reduce latency in testing
# (the model doesn't gate on it and emits no <think> tags) — left here as a
# general knob for other models, not a guaranteed speed fix.
# AI_SYSTEM_PREFIX=detailed thinking off
